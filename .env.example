NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-strong-random-secret
# AUTH_SECRET can also be used by some deploy providers. Keep it equal to NEXTAUTH_SECRET if you set both.
# AUTH_SECRET=replace-with-a-strong-random-secret
NEXT_PUBLIC_SITE_URL=http://localhost:3000

DATABASE_URL=postgresql://postgres:replace-password@replace-host:5432/llcargentina
DIRECT_URL=postgresql://postgres:replace-password@replace-host:5432/llcargentina

BLOG_ADMIN_EMAIL=admin@llcargentina.io
BLOG_ADMIN_PASSWORD=replace-with-a-strong-admin-password

# S3 Media Storage
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-with-aws-access-key
AWS_SECRET_ACCESS_KEY=replace-with-aws-secret-access-key
S3_BUCKET_NAME=replace-with-bucket-name
# Public bucket URL without trailing slash. Example: https://your-bucket.s3.us-east-1.amazonaws.com
S3_PUBLIC_URL=https://your-bucket.s3.us-east-1.amazonaws.com

NEXT_PUBLIC_PANEL_BASE_URL=https://panel.startcompanies.io
